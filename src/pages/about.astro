---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile, projects } from '../data/projects.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={`About | ${profile.name} Portfolio`}>
  <main class="page-shell">
    <nav class="page-nav" aria-label="Portfolio navigation">
      <a href={`${base}/`}>Desktop</a>
      <a href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
    </nav>

    <section class="profile-hero">
      <p class="eyebrow">Interview Portfolio</p>
      <h1>{profile.name}</h1>
      <p class="lead">
        以全端工程、串流資料處理與 3D 視覺化為主軸，將長晶爐即時監控專案整理成可展示的作品集。
      </p>
      <div class="hero-actions">
        <a class="primary-link" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
        <a class="secondary-link" href={`${base}/projects/${projects[0].slug}/`}>Featured Project</a>
      </div>
    </section>

    <section class="content-band">
      <h2>Focus</h2>
      <div class="focus-grid">
        <article>
          <h3>Event-driven backend</h3>
          <p>Spring Cloud 微服務、Gateway、安全流程與多儲存層整合。</p>
        </article>
        <article>
          <h3>Streaming data</h3>
          <p>MQTT、Kafka、Flink CEP 與可驗證的資料流部署流程。</p>
        </article>
        <article>
          <h3>Interactive frontend</h3>
          <p>Vue 儀表板、即時圖表與 Three.js 3D 監控體驗。</p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
